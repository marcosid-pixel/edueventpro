# Turso Database Configuration
# Get these from your Turso dashboard (turso.tech)
TURSO_DATABASE_URL="libsql://your-db-name-user.turso.io"
TURSO_AUTH_TOKEN="your-auth-token"

# Session Configuration
SESSION_SECRET="a-very-long-and-random-string"

# Initial Admin Setup (only used if no users exist in the database)
# Remove these after first admin is created
ADMIN_EMAIL="admin@exemplo.com"
ADMIN_PASSWORD="sua-senha-forte-aqui"
ADMIN_NAME="Administrador"

# CORS: allowed origin (default http://localhost:3000)
CORS_ORIGIN="http://localhost:3000"

# Optional: Gemini API Key (handled by AI Studio automatically)
GEMINI_API_KEY=""
